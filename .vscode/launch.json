{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Attach to Debug",
            "type": "debugpy",
            "request": "attach",
            "connect": {
                "host": "localhost",
                "port": 5679
            },
            "pathMappings": [
                {
                    "localRoot": "${workspaceFolder}/rpi-pico-servo-python",
                    "remoteRoot": "."
                }
            ]
        }
    ]
}