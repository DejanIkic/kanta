# Environment variables example za RPi Pico Servo Control
# Kopiraj u .env i prilagodi potrebne vrednosti

# Database konfiguracija
DATABASE_URL=postgresql://postgres:password@localhost:5432/servo_db

# Serial port konfiguracija
SERIAL_PORT=/dev/ttyACM10
SERIAL_BAUDRATE=115200
SERIAL_TIMEOUT=1.0

# API konfiguracija
API_TITLE="RPi Pico Servo Control API"
API_VERSION="1.0.0"
API_DESCRIPTION="API za kontrolu SG90 servo motora preko Raspberry Pi Pico"

# Logging konfiguracija
LOG_LEVEL=INFO
LOG_FORMAT=json

# Servo postavke
# Servo orientation: vertical or horizontal
SERVO_ORIENTATION=horizontal
SERVO_MOVE_TIMEOUT=2.0

# Health check postavke
HEALTH_CHECK_INTERVAL=30.0

# Development/Production
ENVIRONMENT=development
DEBUG=true
