    {
      "name": "Material Positioning Tests",
      "item": [
        {
          "name": "Plastic Position",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/servo/material/plastic",
              "host": ["{{base_url}}"],
              "path": ["api", "servo", "material", "plastic"]
            }
          },
          "response": [],
          "test": {
            "script": {
              "exec": [
                "// Test plastic positioning",
                "pm.test('Status code is 200', function () {",
                "    pm.response.to.have.status(200);",
                "});",
                "",
                "pm.test('Material type is plastic', function () {",
                "    const jsonData = pm.response.json();",
                "    pm.expect(jsonData.material_type).to.eql('plastic');",
                "});",
                "",
                "pm.test('Vertical angle is -90', function () {",
                "    const jsonData = pm.response.json();",
                "    pm.expect(jsonData.vertical_angle).to.eql(-90);",
                "});",
                "",
                "pm.test('Horizontal angle is -20', function () {",
                "    const jsonData = pm.response.json();",
                "    pm.expect(jsonData.horizontal_angle).to.eql(-20);",
                "});",
                "",
                "pm.test('Command type is material', function () {",
                "    const jsonData = pm.response.json();",
                "    pm.expect(jsonData.command_type).to.eql('material');",
                "});",
                "",
                "pm.test('Response time is reasonable (<3000ms)', function () {",
                "    const jsonData = pm.response.json();",
                "    pm.expect(jsonData.response_time_ms).to.be.below(3000);",
                "});"
              ]
            }
          }
        },
