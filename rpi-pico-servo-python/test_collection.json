                "    pm.expect(jsonData).to.have.property('movements');",
                "    pm.expect(jsonData).to.have.property('total_count');",
                "});",
                "",
                "pm.test('Movements is an array', function () {",
                "    const jsonData = pm.response.json();",
                "    pm.expect(jsonData.movements).to.be.an('array');",
                "});"
              ]
