        {
          "name": "Invalid Material - Should Fail",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/servo/material/metal",
              "host": ["{{base_url}}"],
              "path": ["api", "servo", "material", "metal"]
