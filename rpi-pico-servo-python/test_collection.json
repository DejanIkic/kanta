    {
      "name": "Status and History Tests",
      "item": [
        {
          "name": "Get Servo Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/servo/status",
              "host": ["{{base_url}}"],
              "path": ["api", "servo", "status"]
            }
          },
          "response": [],
          "test": {
            "script": {
              "exec": [
                "// Test servo status",
                "pm.test('Status code is 200', function () {",
                "    pm.response.to.have.status(200);",
                "});",
                "",
                "pm.test('Status response has required fields', function () {",
                "    const jsonData = pm.response.json();",
                "    pm.expect(jsonData).to.have.property('connected');",
                "    pm.expect(jsonData).to.have.property('total_movements');",
                "    pm.expect(jsonData).to.have.property('error_rate');",
                "});",
                "",
                "pm.test('Error rate is valid percentage', function () {",
                "    const jsonData = pm.response.json();",
                "    pm.expect(jsonData.error_rate).to.be.at.least(0);",
                "    pm.expect(jsonData.error_rate).to.be.at.most(100);",
                "});"
              ]
            }
          }
        },
        {
          "name": "Get Servo History",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/servo/history",
              "host": ["{{base_url}}"],
              "path": ["api", "servo", "history"]
